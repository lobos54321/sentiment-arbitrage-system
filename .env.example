# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here

# GMGN Configuration (for execution)
GMGN_API_KEY=your_gmgn_api_key_if_available
GMGN_WALLET_ADDRESS=your_wallet_address_for_gmgn

# Blockchain RPC Endpoints
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Or use premium endpoints for better performance:
# SOLANA_RPC_URL=https://rpc.helius.xyz/?api-key=YOUR_KEY
# SOLANA_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY

BSC_RPC_URL=https://bsc-dataseed.binance.org
# Or: BSC_RPC_URL=https://bsc-dataseed1.ninicoin.io

# API Keys for Data Sources
DEXSCREENER_API_KEY=optional_but_recommended
BIRDEYE_API_KEY=optional_for_solana_data
HELIUS_API_KEY=optional_for_solana_advanced_features
BSCSCAN_API_KEY=optional_for_bsc_contract_verification

# Twitter/X API (for X Validator module)
TWITTER_BEARER_TOKEN=optional_twitter_bearer_token
TWITTER_API_KEY=optional
TWITTER_API_SECRET=optional

# Database
DB_PATH=./data/sentiment_arb.db

# System Configuration
NODE_ENV=production  # development | production | shadow
LOG_LEVEL=info       # debug | info | warn | error

# Safety Limits
MAX_CONCURRENT_POSITIONS=10
MAX_DAILY_TRADES=50
TOTAL_CAPITAL_SOL=10.0
TOTAL_CAPITAL_BNB=1.0

# Execution Settings (can override config.json)
AUTO_BUY_ENABLED=false  # Set to true for auto execution
SHADOW_MODE=true        # Set to false for live trading

# Monitoring & Alerts
ALERT_TELEGRAM_CHAT_ID=same_as_admin_or_different_channel
ENABLE_TRADE_ALERTS=true
ENABLE_ERROR_ALERTS=true

# Advanced (Optional)
JITO_TIP_LAMPORTS=10000  # For Solana MEV protection
CUSTOM_PRIORITY_FEE_SOL=0.001
CUSTOM_SLIPPAGE_BSC=15

# Performance Optimization
CACHE_TTL_SECONDS=60
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Shared market-data rollout flags
MARKET_DATA_UNIFIED_ROLLOUT=true
MARKET_DATA_SHARED_POOL_RESOLUTION=true
MARKET_DATA_SHARED_OHLCV=true
MARKET_DATA_SHARED_QUOTES=true
MARKET_DATA_SHARED_REDIS_CACHE=false
MARKET_DATA_UNIFIED_PREMIUM=true
MARKET_DATA_UNIFIED_PAPER_MONITOR=true
MARKET_DATA_UNIFIED_AUTONOMY=true

# ==========================================
# Premium Channel Mode (付费频道信号)
# ==========================================
# 启用: npm run premium 或设置 PREMIUM_MODE_ENABLED=true
PREMIUM_MODE_ENABLED=false
PREMIUM_CHANNEL_ID=3636518327          # Egeye AI Gems 100X Vip 频道 ID
PREMIUM_POSITION_SOL=0.1               # 每笔仓位大小 (SOL)
PREMIUM_MAX_POSITIONS=5                # 最大并发持仓数

# Paper execution penalty (neutral profile)
PAPER_EXECUTION_PENALTY_ENABLED=true
PAPER_BUY_SLIPPAGE_BPS=35
PAPER_SELL_SLIPPAGE_BPS=50
PAPER_BUY_DELAY_BPS=15
PAPER_SELL_DELAY_BPS=25
PAPER_FEE_BPS=8

# AI Analysis (Claude API for Premium Channel)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
