      "mutation_anchor": "action: 'pause_trading'",
      "mutation_write_path_ids": ["dashboard.system_state.pause_trading"]
    },
    {
      "action_id": "resume_trading_route_split",
      "view_route": "/api/trading-status",
      "mutation_route": "/api/resume-trading",
      "separation_enforced": true,
      "audit_required": true,
      "view_anchor": "const status = rm.getStatus();",
      "mutation_anchor": "action: 'resume_trading'",
      "mutation_write_path_ids": ["dashboard.system_state.resume_trading"]
    },
    {
      "action_id": "reset_daily_loss_route_split",
      "view_route": "/api/trading-status",
      "mutation_route": "/api/reset-daily-loss",
      "separation_enforced": true,
      "audit_required": true,
      "view_anchor": "const status = rm.getStatus();",
      "mutation_anchor": "action: 'reset_daily_loss'",
      "mutation_write_path_ids": ["dashboard.system_state.reset_daily_loss"]
