  "scope": "local_and_zeabur_data_directory_storage_pressure",
  "failure_action": "storage_degraded",
  "source_file": "src/web/dashboard-server.js",
  "source_anchors": [
    "fs.statfsSync(dataDir)",
    "free_bytes: free",
