# Minimal config for testing (Shadow Mode, No AI)

# Database
DB_PATH=./data/sentiment_arb.db

# System Mode - SHADOW (no real trades)
NODE_ENV=development
SHADOW_MODE=true
AUTO_BUY_ENABLED=false
LOG_LEVEL=info

# Blockchain RPC (public endpoints)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Safety Limits
MAX_CONCURRENT_POSITIONS=5
MAX_DAILY_TRADES=20
TOTAL_CAPITAL_SOL=1.0
TOTAL_CAPITAL_BNB=0.1

# Premium Mode - DISABLED
PREMIUM_MODE_ENABLED=false

# AI Analysis - DISABLED (no API key needed)
# ANTHROPIC_API_KEY=

# Telegram - placeholder (won't work without real tokens)
TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_ADMIN_CHAT_ID=placeholder
USE_PRICE_MONITOR_V2=true
